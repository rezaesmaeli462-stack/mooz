def format_toman(amount):
    return f"{amount:,} تومان"

def plan_description(plan):
    if plan["unlimited"]:
        return "👤 ۱ کاربره | ⏱ ۳۰ روزه | ⚡️ سرعت بالا"
    return "👥 کاربر نامحدود | ⏱ زمان نامحدود | ⚡️ سرعت بالا"

async def show_plan_selector(query, index):
    plan = PLANS[index]
    desc = plan_description(plan)
    price = format_toman(plan["toman"])

    text = (
        f"📦 *انتخاب حجم کانفیگ*\n\n"
        f"✅ {desc}\n\n"
        f"📌 پلن انتخابی: *{plan['name']}*\n"
        f"💵 قیمت: *{price}*\n\n"
        f"برای تغییر حجم از دکمه‌های ➕ و ➖ استفاده کنید."
    )

    # پلن‌های معمولی (بدون نامحدود)
    normal_plans = [p for p in PLANS if not p["unlimited"]]
    current_normal_index = next((i for i, p in enumerate(normal_plans) if p["name"] == plan["name"]), None)

    keyboard = []

    if not plan["unlimited"]:
        keyboard.append([
            InlineKeyboardButton("➖", callback_data=f"plan_down_{index}"),
            InlineKeyboardButton(f"{plan['name']}", callback_data="noop"),
            InlineKeyboardButton("➕", callback_data=f"plan_up_{index}"),
        ])
        keyboard.append([InlineKeyboardButton("♾ کانفیگ نامحدود", callback_data=f"plan_select_{len(PLANS)-1}")])
    else:
        # نمایش دکمه برگشت به پلن‌های حجمی
        keyboard.append([InlineKeyboardButton("📦 کانفیگ حجمی", callback_data=f"plan_select_0")])

    keyboard.append([InlineKeyboardButton("✅ تأیید و ادامه", callback_data=f"confirm_plan_{index}")])
    keyboard.append([InlineKeyboardButton("🔙 بازگشت", callback_data="back_main")])

    await query.edit_message_text(text, reply_markup=InlineKeyboardMarkup(keyboard), parse_mode="Markdown")

async def plan_navigate(update: Update, context: ContextTypes.DEFAULT_TYPE):
    query = update.callback_query
    await query.answer()
    uid = query.from_user.id
    data = query.data

    if "plan_select" in data:
        idx = int(data.split("_")[2])
    elif "plan_up" in data:
        current = int(data.split("_")[2])
        # فقط بین پلن‌های غیر نامحدود جابجا بشه
        idx = min(current + 1, len(PLANS) - 2)
    else:  # plan_down
        current = int(data.split("_")[2])
        idx = max(current - 1, 0)

    user_states[uid] = {"method": "card", "plan_index": idx}
    await show_plan_selector(query, idx)

