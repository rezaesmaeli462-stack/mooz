# ==================== تأیید / رد سفارش ====================
async def approve_order(update: Update, context: ContextTypes.DEFAULT_TYPE):
    query = update.callback_query
    if query.from_user.id != ADMIN_ID:
        await query.answer("❌ شما ادمین نیستید!", show_alert=True)
        return
    await query.answer()

    parts = query.data.split("_")
    target_uid = int(parts[1])
    idx = int(parts[2])
    plan = PLANS[idx]

    user_states[ADMIN_ID] = {"sending_config_to": target_uid, "plan_index": idx}
    purchase_counts[target_uid] = purchase_counts.get(target_uid, 0) + 1

    try:
        await query.edit_message_caption(
            caption=(query.message.caption or "") + "\n\n✅ *تأیید شد - در انتظار ارسال کانفیگ*",
            parse_mode="Markdown"
        )
    except:
        pass

    await context.bot.send_message(
        chat_id=target_uid,
        text=(
            f"✅ *سفارش شما تأیید شد!*\n\n"
            f"📦 پلن: {plan['name']}\n\n"
            f"کانفیگ شما به زودی ارسال می‌شود. 🙏"
        ),
        parse_mode="Markdown"
    )
    await context.bot.send_message(
        chat_id=ADMIN_ID,
        text=f"📤 حالا کانفیگ کاربر `{target_uid}` را ارسال کنید:\n(متن، عکس یا فایل)",
        parse_mode="Markdown"
    )

