# ==================== هندلر پیام‌های عمومی ====================
async def handle_text(update: Update, context: ContextTypes.DEFAULT_TYPE):
    uid = update.effective_user.id

    if uid == ADMIN_ID:
        state = user_states.get(uid, {})
        if state.get("sending_config_to"):
            await admin_send_config(update, context)
            return
        if update.message.reply_to_message:
            if await admin_reply_support(update, context):
                return
        return

    state = user_states.get(uid, {})
    if state.get("waiting_support"):
        await receive_support_message(update, context)
    elif state.get("waiting_receipt"):
        await update.message.reply_text("❌ لطفاً عکس رسید را ارسال کنید.")

async def handle_photo(update: Update, context: ContextTypes.DEFAULT_TYPE):
    uid = update.effective_user.id

    if uid == ADMIN_ID:
        state = user_states.get(uid, {})
        if state.get("sending_config_to"):
            await admin_send_config(update, context)
            return
        return

    state = user_states.get(uid, {})
    if state.get("waiting_receipt"):
