# ==================== ارسال کانفیگ توسط ادمین ====================
async def admin_send_config(update: Update, context: ContextTypes.DEFAULT_TYPE):
    uid = ADMIN_ID
    state = user_states.get(uid, {})
    target = state.get("sending_config_to")
    if not target:
        return False

    keyboard = [[InlineKeyboardButton("🏠 منوی اصلی", callback_data="back_main")]]
    intro = "✅ *کانفیگ شما آماده است:*\n\n"
    config_text = ""

    if update.message.text:
        config_text = update.message.text
        await context.bot.send_message(
            chat_id=target,
            text=intro + config_text,
            parse_mode="Markdown",
            reply_markup=InlineKeyboardMarkup(keyboard)
        )
    elif update.message.photo:
        config_text = update.message.caption or "کانفیگ تصویری"
        await context.bot.send_photo(
            chat_id=target,
            photo=update.message.photo[-1].file_id,
            caption=intro + config_text,
            parse_mode="Markdown",
            reply_markup=InlineKeyboardMarkup(keyboard)
        )
    elif update.message.document:
        config_text = update.message.caption or "کانفیگ فایل"
        await context.bot.send_document(
            chat_id=target,
            document=update.message.document.file_id,
            caption=intro + config_text,
            parse_mode="Markdown",
            reply_markup=InlineKeyboardMarkup(keyboard)
        )
    else:
        return False

    # ذخیره کانفیگ برای «سرویس‌های من»
    plan = PLANS[state.get("plan_index", 0)]
    entry = f"📦 {plan['name']}\n🔑 {config_text}"
    if target not in user_configs:
        user_configs[target] = []
    user_configs[target].append(entry)

    user_states[uid].pop("sending_config_to", None)
    user_states[uid].pop("plan_index", None)
    await update.message.reply_text(f"✅ کانفیگ با موفقیت برای کاربر `{target}` ارسال شد.", parse_mode="Markdown")
    return True

